; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Grimheart"
config/description="Grimheart is an Open Source, FPS, Apocalypse Simulation. It takes inspiration and cues from peers in its genre such as Project Zomboid, Cataclysm, and Escape from Tarkov."
config/version="Pre-Alpha"
run/main_scene="uid://c3wthaj2pok5q"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.5254902, 0.7490196, 0.56078434, 1)
boot_splash/stretch_mode=0
boot_splash/use_filter=false
boot_splash/image="uid://cpdakj60wqbny"
config/icon="uid://cpdakj60wqbny"

[autoload]

Debug="*uid://cr74nwug55noi"

[display]

window/size/always_on_top=true
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0
window/physics_jitter_fix=0.5
window/physics_ticks_per_second=144

[editor_plugins]

enabled=PackedStringArray("res://addons/MarchingSquaresTerrain/plugin.cfg", "res://addons/asset_placer/plugin.cfg", "res://addons/open-world-database/plugin.cfg")

[filesystem]

import/blender/enabled=false

[global_group]

Zombies=""

[gui]

fonts/dynamic_fonts/use_oversampling=false
theme/default_font_antialiasing=0
theme/default_font_subpixel_positioning=0

[importer_defaults]

scene={
"_subresources": {},
"animation/fps": 30,
"animation/import": true,
"animation/import_rest_as_RESET": false,
"animation/remove_immutable_tracks": true,
"animation/trimming": false,
"gltf/embedded_image_handling": 3,
"gltf/naming_version": 1,
"import_script/path": "",
"meshes/create_shadow_meshes": true,
"meshes/ensure_tangents": true,
"meshes/force_disable_compression": true,
"meshes/generate_lods": true,
"meshes/light_baking": 2,
"meshes/lightmap_texel_size": 0.2,
"nodes/apply_root_scale": true,
"nodes/import_as_skeleton_bones": false,
"nodes/root_name": "",
"nodes/root_scale": 1.0,
"nodes/root_type": "Node3D",
"nodes/use_node_type_suffixes": true,
"skins/use_named_skins": true
}

